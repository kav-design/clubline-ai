{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/login", "destination": "https://clubline-ai-dashboard.vercel.app/login", "permanent": false },
    { "source": "/signup", "destination": "https://clubline-ai-dashboard.vercel.app/signup", "permanent": false },
    { "source": "/forgot-password", "destination": "https://clubline-ai-dashboard.vercel.app/forgot-password", "permanent": false },
    { "source": "/reset-password", "destination": "https://clubline-ai-dashboard.vercel.app/reset-password", "permanent": false },
    { "source": "/callback", "destination": "https://clubline-ai-dashboard.vercel.app/callback", "permanent": false },
    { "source": "/demo", "destination": "https://clubline-ai-dashboard.vercel.app/demo", "permanent": false },
    { "source": "/dashboard/:path*", "destination": "https://clubline-ai-dashboard.vercel.app/dashboard/:path*", "permanent": false }
  ]
}
